{
  "expo": {
    "name": "EndurACE",
    "slug": "endurace",
    "owner": "gemalfaros-organization",
    "version": "1.0.0",
    "sdkVersion": "50.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "endurace",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#010101"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.endurace.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#010101"
      },
      "package": "com.endurace.mobile",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://endurace.onrender.com",
      "eas": {
        "projectId": "dd1cb1df-c861-4074-8fc4-2f3fb1ef117e"
      }
    }
  }
}